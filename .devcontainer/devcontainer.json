// For format details, see https://containers.dev/implementors/json_reference/.
{
  "name": "super_projects",
  "dockerComposeFile": "compose.yaml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/",
  "shutdownAction": "none",
  "mounts": [
    "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind",
    // For the following source path to work correctly when using devcontainers through VSCode/Cursor with WSL
    // you will need to enable the user setting "dev.containers.executeInWSL"
    "source=~/.ssh,target=/home/developer/.ssh,type=bind,consistency=cached"
  ],

  "remoteUser": "developer",
  "updateRemoteUserUID": true,

  // Populate .devcontainer/.env with host UID and docker.sock GID before the image is built.
  // Docker Compose resolves ${VAR} substitutions from the .env file in the same directory as
  // the compose file (.devcontainer/), so the file must live there — not at the workspace root.
  // Also pre-create the gemini-data bind-mount dir so Docker doesn't create it as root.
  "initializeCommand": "sh -c 'printf \"DEVELOPER_UID=$(id -u)\\nDOCKER_GID=$(stat -c \"%g\" /var/run/docker.sock)\\n\" > .devcontainer/.env && mkdir -p .devcontainer/gemini-data'",

  // Expose localWorkspaceFolder so tools inside the container can reference the host path
  "remoteEnv": { "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}" },

  "containerEnv": {
    "EDITOR": "code",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },

  // VNC/noVNC/Chrome stack is started by the container's own command in compose.yaml,
  // so it works with plain `docker compose up` without needing this hook.
  // Desktop available at http://localhost:6080/vnc.html (no password).

  // Explicitly forward VNC ports so Cursor/VSCode creates a proper tunnel that
  // supports WebSocket upgrades. Without this, Docker Desktop's host-network
  // proxy handles HTTP fine but drops WebSocket upgrade connections.
  // "forwardPorts": [6080, 5900, 8080],
  // "portsAttributes": {
  //   "6080": { "label": "noVNC (browser)", "onAutoForward": "notify" },
  //   "5900": { "label": "VNC", "onAutoForward": "silent" },
  //   "8080": { "label": "Chrome DevTools MCP", "onAutoForward": "silent" }
  // },

  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },

  // Features are largely handled by the Dockerfile directly for finer control,
  // but the equivalent devcontainer features are listed here for reference.
  "features": {
    // "ghcr.io/devcontainers/features/github-cli:1": {},
    // "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
    //   "moby": false,
    //   "dockerDashComposeVersion": "v2"
    // }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "streetsidesoftware.code-spell-checker",
        "eamodio.gitlens",
        "ms-azuretools.vscode-containers"
      ],
      "settings": {}
    }
  }
}
