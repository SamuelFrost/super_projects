# Ignore everything by default — this repo only tracks the dev environment scaffolding,
# not any of the projects that live inside this directory.
*

# Unignore the dev environment and IDE config directories/files
!.gitignore
!.devcontainer/
!.devcontainer/**
!.cursor/
!.cursor/**
!.claude/
!.claude/**
!.vscode/
!.vscode/**
!README.md
!LICENSE
!AGENTS.md
!agents.md
!.mise.toml

# Ignore generated/persisted files even though the parent dirs are whitelisted above
.devcontainer/.env
.devcontainer/gemini-data/
